//------------------<[ Implementacja: ]>-------------------
command_vpn_Impl(playerid)
{
    if(PlayerInfo[playerid][pAdmin] >= 1000 || IsAScripter(playerid))
    {
        HTTP(playerid, HTTP_GET, AC_VPN_IP "/vpn/vpn.php?adm&requests", "", "VPNPanel");
    }
    return 1;
}

