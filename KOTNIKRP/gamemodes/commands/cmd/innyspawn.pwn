 */


// Notatki skryptera:
/*

 */

YCMD:innyspawn(playerid, params[], help)
{
    if(IsPlayerConnected(playerid))
    {
        if(PlayerInfo[playerid][pDom] != 0)
        {
            sendTipMessageEx(playerid, COLOR_GREY, "Uzyj /dom badz /g [slot] spawn!");
        }
    }
    return 1;
}
