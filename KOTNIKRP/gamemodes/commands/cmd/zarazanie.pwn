// Opis:
/*
	
*/

YCMD:zarazanie(playerid, params[], help)
{
    if(PlayerInfo[playerid][pAdmin] < 1000) return noAccessMessage(playerid);
    new zr;
    if(sscanf(params, "d", zr)) return sendTipMessage(playerid, "Użyj: /zarazanie [0 - off, 1 - on]");
    if(zr == Zarazanie) return SendClientMessage(playerid, COLOR_LIGHTGREEN, sprintf("Zarażanie jest już %s!", (zr) ? ("włączone") : ("wyłączone")));
    Zarazanie = zr;
    SendClientMessage(playerid, COLOR_LIGHTGREEN, sprintf("Zarażanie zostało %s!", (Zarazanie) ? ("włączone") : ("wyłączone")));
    return 1;
}