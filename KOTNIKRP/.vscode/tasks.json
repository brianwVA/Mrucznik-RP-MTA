{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "build-normal",
        "type": "process",
        "command": "${workspaceRoot}\\pawncc\\pawncc.exe",
        "args": ["${workspaceRoot}\\gamemodes\\Kotnik-RP.pwn", "-Dgamemodes", "-;+", "-(+", "-d3", "-Z"],
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "isBackground": false,
        "presentation": {
          "reveal": "silent",
          "panel": "dedicated"
        },
        "problemMatcher": "$pawncc"
      }
    ]
  }